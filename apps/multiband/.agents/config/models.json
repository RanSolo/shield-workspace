{
  "defaults": {
    "provider": "local",
    "temperature": 0.8,
    "maxTokens": 1600
  },
  "providers": {
    "local": {
      "baseUrl": "http://127.0.0.1:1234/v1",
      "baseUrlEnv": "LOCAL_MODEL_BASE_URL",
      "apiKey": "lm-studio",
      "apiKeyEnv": "LOCAL_MODEL_API_KEY",
      "chatCompletionsPath": "/chat/completions"
    },
    "openai": {
      "baseUrl": "https://api.openai.com/v1",
      "baseUrlEnv": "OPENAI_BASE_URL",
      "apiKeyEnv": "OPENAI_API_KEY",
      "chatCompletionsPath": "/chat/completions"
    }
  },
  "models": {
    "manager": {
      "provider": "local",
      "model": "ornith-1.0-35b",
      "modelEnv": "MODEL_MANAGER"
    },
    "worker": {
      "provider": "local",
      "model": "ornith-1.0-35b",
      "modelEnv": "MODEL_WORKER"
    },
    "designer": {
      "provider": "local",
      "model": "ornith-1.0-35b",
      "modelEnv": "MODEL_DESIGNER"
    },
    "reviewer": {
      "provider": "local",
      "model": "ornith-1.0-35b",
      "modelEnv": "MODEL_REVIEWER"
    },
    "orchestrator": {
      "provider": "local",
      "model": "ornith-1.0-35b",
      "modelEnv": "MODEL_ORCHESTRATOR"
    },
    "daisy": {
      "provider": "local",
      "model": "ornith-1.0-35b",
      "modelEnv": "MODEL_DAISY"
    },
    "fury": {
      "provider": "openai",
      "model": "gpt-5.6-terra",
      "modelEnv": "MODEL_FURY"
    },
    "mm": {
      "provider": "openai",
      "model": "gpt-5.6",
      "modelEnv": "MODEL_MM"
    }
  },
  "roleAliases": {
    "orchestrator": "manager",
    "daisy": "designer"
  }
}
