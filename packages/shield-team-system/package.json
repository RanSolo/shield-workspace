{
  "name": "@shield/team-system",
  "version": "0.1.0",
  "description": "Portable operating framework for human and AI software delivery",
  "type": "module",
  "main": "./public/index.mjs",
  "types": "./public/index.d.mts",
  "bin": {
    "shield": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./public/index.d.mts",
      "import": "./public/index.mjs"
    },
    "./mission": {
      "types": "./public/mission.d.mts",
      "import": "./public/mission.mjs"
    },
    "./journal": {
      "types": "./public/journal.d.mts",
      "import": "./public/journal.mjs"
    },
    "./modes": {
      "types": "./public/modes.d.mts",
      "import": "./public/modes.mjs"
    },
    "./workspace": {
      "types": "./public/workspace.d.mts",
      "import": "./public/workspace.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "import": "./dist/config.mjs"
    },
    "./supervision": {
      "types": "./dist/mission-v2.d.mts",
      "import": "./dist/mission-v2.mjs"
    },
    "./delegation": {
      "types": "./dist/delegation-v1.d.mts",
      "import": "./dist/delegation-v1.mjs"
    },
    "./adapter": {
      "types": "./dist/adapter-v1.d.mts",
      "import": "./dist/adapter-v1.mjs"
    },
    "./runner": {
      "types": "./dist/runner-v1.d.mts",
      "import": "./dist/runner-v1.mjs"
    },
    "./permission": {
      "types": "./dist/permission-v1.d.mts",
      "import": "./dist/permission-v1.mjs"
    },
    "./permission-audit": {
      "types": "./dist/permission-audit-v1.d.mts",
      "import": "./dist/permission-audit-v1.mjs"
    },
    "./local-tools": {
      "types": "./public/local-tools.d.mts",
      "import": "./public/local-tools.mjs"
    },
    "./github": {
      "types": "./public/github.d.mts",
      "import": "./public/github.mjs"
    }
  },
  "files": [
    "adapters",
    "agents",
    "contracts",
    "dist",
    "github",
    "modes",
    "playbooks",
    "public",
    "scripts",
    "README.md",
    "INSTALLATION.md",
    "SUPERVISED_MISSION.md",
    "WHEELS_OFF.md",
    "PERMISSION_BOUNDARY.md",
    "PUBLIC_API.md",
    "TECHNICAL_DESIGN.md",
    "scorecard.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "pretest": "npm run build",
    "test": "node --test tests/*.test.mjs",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "20.12.12",
    "typescript": "5.4.5"
  }
}
